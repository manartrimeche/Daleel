# ──────────────────────────────────────────────────
# Daleel — Environment Configuration
# Copy to .env and adjust values for your deployment.
# ──────────────────────────────────────────────────

# ── MongoDB ──
DALEEL_MONGODB_URL=mongodb://localhost:27017
DALEEL_MONGODB_DB_NAME=manar

# ── Authentication ──
# Set these to enable API key protection. Leave empty to disable auth (dev mode).
# DALEEL_API_KEY=changeme-some-random-secret
# DALEEL_ADMIN_API_KEY=changeme-admin-secret
# Required for stable login sessions across backend restarts.
# Generate a strong random value and keep it unchanged per environment.
# DALEEL_JWT_SECRET_KEY=changeme-at-least-32-random-characters

# ── Embedding model (auto-downloaded on first run) ──
# DALEEL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# DALEEL_EMBEDDING_DIMENSION=768

# ── Chunking defaults ──
# DALEEL_CHUNK_SIZE=1500
# DALEEL_CHUNK_OVERLAP=200
# DALEEL_MIN_CHUNK_LEN=60

# ── Upload ──
# DALEEL_MAX_UPLOAD_MB=100

# ── LLM ──
# Fournisseur : "ollama" (LLM local, dev) ou "openai" (API compatible OpenAI :
# OpenRouter, Groq, Together, vLLM…). Le pipeline RAG est identique.
DALEEL_LLM_PROVIDER=ollama

# --- Dev local (Ollama) ---
DALEEL_LLM_BASE_URL=http://localhost:11434
DALEEL_LLM_API_KEY=ollama
DALEEL_LLM_MODEL=qwen2.5:7b

# --- Hébergement gratuit (OpenRouter, modèle Qwen2.5 — fidèle au PFE) ---
# DALEEL_LLM_PROVIDER=openai
# DALEEL_LLM_BASE_URL=https://openrouter.ai/api/v1
# DALEEL_LLM_API_KEY=sk-or-...        # clé OpenRouter (https://openrouter.ai/keys)
# DALEEL_LLM_MODEL=openai/gpt-oss-120b:free   # modèle gratuit fiable (testé, pas de 429) ; :free = gratuit
# Autres options compatibles : Groq (https://api.groq.com/openai/v1),
# Together (https://api.together.xyz/v1), etc.
# ENABLE_CROSS_ENCODER=true

# ── LLM resilience ──
# DALEEL_LLM_MAX_RETRIES=3
# DALEEL_LLM_TIMEOUT_CONNECT=15.0
# DALEEL_LLM_TIMEOUT_READ=300.0
# DALEEL_LLM_BACKOFF_BASE=1.0
# DALEEL_LLM_BACKOFF_MAX=16.0
# DALEEL_LLM_KEEP_ALIVE=10m
DALEEL_LLM_CACHE_TTL_SECONDS=3600
DALEEL_LLM_CACHE_MAX_SIZE=500
# Also accepted aliases:
LLM_CACHE_TTL_SECONDS=3600
LLM_CACHE_MAX_SIZE=500

# ── Vector search ──
# "faiss" (default, fast) or "python-cosine" (legacy fallback)
# DALEEL_VECTOR_SEARCH_BACKEND=faiss
# FAISS_HNSW_M=32
# FAISS_HNSW_EF_CONSTRUCTION=200
# FAISS_HNSW_EF_SEARCH=64
#FAISS_SKIP_DIM_VALIDATION=true
# ── Tesseract path (Windows) ──
# DALEEL_TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── CORS ──
# Comma-separated allowed origins. Use "*" only for local dev.
# DALEEL_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Auto mode routing ──
# DALEEL_AUTO_MODE_ENABLED=true
# DALEEL_AUTO_MODE_LENGTH_THRESHOLD=240

# ── Answer grounding policy ──
# DALEEL_STRICT_GROUNDED_ONLY=false

# ── Sprint 6+ : Domain-aware RAG ──
# Routes questions to legal-domain-specific retrieval configs (labor, corporate, etc.)
# DALEEL_DOMAIN_ROUTER_ENABLED=true
# DALEEL_DOMAIN_ROUTER_LLM_FALLBACK_ENABLED=true

# ── Sprint 6+ : Partitioned Retrieval Orchestrator ──
# Separates base-law retrieval from amendment retrieval based on question intent.
# DALEEL_PARTITIONED_RETRIEVAL_ENABLED=true

# ── Sprint 6+ : Quality Guard (hallucination detection) ──
# Post-generation audit: reference validation, semantic fidelity, conservative rewrite.
# DALEEL_QUALITY_GUARD_ENABLED=true
# Calls the LLM a second time to judge semantic fidelity. Keep false for faster responses.
# DALEEL_QUALITY_GUARD_SEMANTIC_CHECK_ENABLED=false

# ── Sprint 6+ : KG Light Enrichment ──
# Injects structured graph relations (Loi→Article→Exigence→Action) into RAG context.
# DALEEL_KG_LIGHT_ENABLED=true
# DALEEL_KG_LIGHT_MAX_ENTITIES=6

# ── Fine-tuning: Track 1 — Style Model (LoRA via Ollama) ──
# Nom du modèle Ollama (ex: daleel-style — sans tag pour éviter les erreurs Ollama)
# DALEEL_STYLE_MODEL=daleel-style
# DALEEL_STYLE_MODEL_ENABLED=true
# DALEEL_STYLE_MODEL_TIMEOUT=30.0

# ── Fine-tuning: Track 2 — Reasoning Model (XLM-R multi-head classifier) ──
# Chemin vers le répertoire contenant model.pt et labels.json
# DALEEL_REASONING_MODEL_PATH=backend/training/models/daleel-reasoning-v2
# Seuil de confiance minimum pour accepter la prédiction (0.0–1.0)
# DALEEL_REASONING_CONFIDENCE_THRESHOLD=0.7
